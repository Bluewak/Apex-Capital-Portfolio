# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# uv / venv
.venv/
venv/

# 데이터 캐시·산출 아티팩트. 재현성 소스 핀(snapshots·rates)은 커밋,
# 파생물(registry)·런타임(ledger)은 무시(코드+핀에서 재생성).
# 루트 앵커(/) 필수 — 없으면 소스 패키지 src/apex/data/까지 무시됨
/data/
/artifacts/*
!/artifacts/snapshots/
!/artifacts/rates/
*.parquet
*.feather

# 도구 산출물 (생성물 — 스크립트로 재생성)
tools/sp500/*.html

# 테스트/커버리지
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# 환경/비밀
.env
.env.*

# OS/IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
